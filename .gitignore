# --- project-specific ---
# 370M+ uv venv; recreate with uv, don't commit
.venv/
# app.log, app.run.log, etc.
*.log
# scratch / deprecated code
trash/
# per-user "save settings as default" overrides (written at runtime by app.py)
user_defaults.json

# Video media (source/*.mp4 is a symlink to a file outside the repo, and render
# outputs like onnx_preview.mp4 are large build artefacts). Keep the small still
# test fixtures (source/*.webp, *.png) tracked.
*.mp4
*.mkv
*.mov
*.avi
*.webm
*.m4v
*.ts
*.mpg
*.mpeg

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/
.installed.cfg

# Virtual envs (other common names)
venv/
env/
ENV/
.env

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/
.claude/

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp
